{
    "test_name": "test_tcp_connect",
    "test_description": "Basic TCP connect/disconnect cycle. Verifies that the client can connect to the server and then disconnect cleanly.",
    "timeout": 10,

    "variable_config": {
        "environment": {
            "work_dir": "/tmp",
            "console_log_handlers": {},
            "daemon_log_handlers": {}
        },
        "yuno": {
            "autoplay": true,
            "required_services": [],
            "public_services": [],
            "service_descriptor": {},
            "trace_levels": {
                "C_TCP": ["connections"],
                "C_TCP_S": ["listen"]
            }
        },
        "global": {
            "__input_side__.__json_config_variables__": {
                "__input_url__": "tcp://0.0.0.0:7790",
                "__input_host__": "0.0.0.0",
                "__input_port__": "7790"
            }
        },
        "services": [
            {
                "name": "__input_side__",
                "gclass": "C_IOGATE",
                "autostart": true,
                "autoplay": false,
                "kw": {},
                "children": [
                    {
                        "name": "server_port",
                        "gclass": "C_TCP_S",
                        "kw": {
                            "url": "(^^__input_url__^^)",
                            "child_tree_filter": {
                                "kw": {
                                    "__gclass_name__": "C_CHANNEL",
                                    "__disabled__": false,
                                    "connected": false
                                }
                            }
                        }
                    }
                ],
                "[^^children^^]": {
                    "__range__": [1, 1],
                    "__vars__": {},
                    "__content__": {
                        "name": "(^^__input_port__^^)-(^^__range__^^)",
                        "gclass": "C_CHANNEL",
                        "children": [
                            {
                                "name": "(^^__input_port__^^)-(^^__range__^^)",
                                "gclass": "C_PROT_TCP4H",
                                "kw": {},
                                "children": [
                                    {
                                        "gclass": "C_TCP"
                                    }
                                ]
                            }
                        ]
                    }
                }
            },
            {
                "name": "__output_side__",
                "gclass": "C_IOGATE",
                "autostart": false,
                "autoplay": false,
                "children": [
                    {
                        "name": "output",
                        "gclass": "C_CHANNEL",
                        "children": [
                            {
                                "name": "output",
                                "gclass": "C_PROT_TCP4H",
                                "kw": {},
                                "children": [
                                    {
                                        "name": "output",
                                        "gclass": "C_TCP",
                                        "kw": {
                                            "url": "tcp://127.0.0.1:7790"
                                        }
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    },

    "script": [
        {
            "action": "subscribe",
            "target": "__output_side__",
            "comment": "Subscribe to output_side events"
        },
        {
            "action": "wait_timeout",
            "ms": 500,
            "comment": "Wait for server to be ready"
        },
        {
            "action": "start_tree",
            "target": "__output_side__",
            "comment": "Start TCP client connection"
        },
        {
            "action": "wait_event",
            "source": "__output_side__",
            "event": "EV_ON_OPEN",
            "timeout": 5,
            "comment": "Wait for TCP connection established"
        },
        {
            "action": "wait_timeout",
            "ms": 500,
            "comment": "Stay connected briefly"
        },
        {
            "action": "send_event",
            "target": "__output_side__",
            "event": "EV_DROP",
            "kw": {},
            "comment": "Disconnect from server"
        },
        {
            "action": "wait_event",
            "source": "__output_side__",
            "event": "EV_ON_CLOSE",
            "timeout": 5,
            "comment": "Wait for disconnect confirmation"
        }
    ],

    "expected_errors": [],

    "expected_event_trace": [
        {"event": "EV_ON_OPEN"},
        {"event": "EV_ON_CLOSE"}
    ]
}
