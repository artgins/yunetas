{
    "name": "@yuneta/lib-yui",
    "version": "7.3.0",
    "type": "module",
    "main": "dist/lib-yui.cjs.js",
    "module": "dist/lib-yui.es.js",
    "exports": {
        ".": {
            "import": "./dist/lib-yui.es.js",
            "require": "./dist/lib-yui.cjs.js"
        },
        "./src/*": "./src/*",
        "./vite-plugin-yuneta-html.js": "./vite-plugin-yuneta-html.js",
        "./skeleton/*": "./skeleton/*"
    },
    "files": [
        "dist/",
        "index.js",
        "src/",
        "skeleton/",
        "vite-plugin-yuneta-html.js"
    ],
    "description": "Yuneta UI Library — GClass-based GUI components: app shell, windows, forms, maps, charts, TreeDB editors",
    "scripts": {
        "build": "vite build",
        "test": "node --test tests/*.test.mjs",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@rollup/plugin-terser": "^1.0.0",
        "vite": "^8.0.10"
    },
    "peerDependencies": {
        "@yuneta/gobj-js": "*",
        "@antv/g6": "^5.1.0",
        "bulma": "^1.0.4",
        "i18next": "^26.0.7",
        "maplibre-gl": "^5.24.0",
        "tabulator-tables": "^6.4.0",
        "tom-select": "^2.6.0",
        "uplot": "^1.6.32",
        "vanilla-jsoneditor": "^0.23.0"
    }
}
