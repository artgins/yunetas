{
    "name": "@yuneta/lib-yui",
    "version": "8.0.0",
    "type": "module",
    "main": "dist/lib-yui.cjs.js",
    "module": "dist/lib-yui.es.js",
    "exports": {
        ".": {
            "import": "./dist/lib-yui.es.js",
            "require": "./dist/lib-yui.cjs.js"
        },
        "./src/*": "./src/*",
        "./vite-plugin-yuneta-html.js": "./vite-plugin-yuneta-html.js",
        "./skeleton/*": "./skeleton/*"
    },
    "files": [
        "dist/",
        "index.js",
        "src/",
        "skeleton/",
        "vite-plugin-yuneta-html.js"
    ],
    "description": "Yuneta UI Library — legacy GClass GUI stack (C_YUI_MAIN/WINDOW/TABS/ROUTING + TreeDB editors + charts/maps).  Declarative shell (C_YUI_SHELL+NAV+PAGER+WIZARD) moved to wattyzer/gui/src/lib-yui in v8.0.",
    "scripts": {
        "build": "vite build",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@rollup/plugin-terser": "^1.0.0",
        "@yuneta/gobj-js": "file:../gobj-js",
        "vite": "^8.0.10"
    },
    "peerDependencies": {
        "@yuneta/gobj-js": "^7.3.4",
        "@antv/g6": "^5.1.0",
        "bulma": "^1.0.4",
        "i18next": "^26.0.7",
        "maplibre-gl": "^5.24.0",
        "tabulator-tables": "^6.4.0",
        "tom-select": "^2.6.0",
        "uplot": "^1.6.32",
        "vanilla-jsoneditor": "^0.23.0"
    }
}
