{
    "_comment": "Main declarative config for C_YUI_SHELL. Exercises: vertical (left), icon-bar (bottom), tabs (top-sub), drawer (overlay), eager lifecycle (help), toolbar with hamburger + home.",

    "shell": {
        "breakpoints": "bulma",

        "zones": {
            "top":        { "host": "toolbar",        "show_on": ">=tablet" },
            "left":       { "host": "menu.primary",   "show_on": ">=desktop" },
            "bottom":     { "host": "menu.primary",   "show_on": "<desktop"  },
            "top-sub":    { "host": "menu.secondary", "show_on": "<desktop"  },
            "right":      { "host": "menu.secondary", "show_on": ">=desktop" },
            "center":     { "host": "stage.main" }
        },

        "stages": {
            "main": { "zone": "center", "default_route": "/dash/ov" }
        }
    },

    "toolbar": {
        "zone": "top",
        "aria_label": "App toolbar",
        "items": [
            {
                "id": "burger",
                "icon": "icon-menu",
                "name": "",
                "aria_label": "Open quick menu",
                "action": { "type": "drawer", "op": "toggle", "menu_id": "quick" }
            },
            {
                "id": "home",
                "icon": "icon-home",
                "name": "Home",
                "action": { "type": "navigate", "route": "/dash/ov" }
            },
            {
                "id": "help",
                "icon": "icon-help",
                "name": "Help",
                "align": "end",
                "action": { "type": "navigate", "route": "/help" }
            }
        ]
    },

    "menu": {
        "primary": {
            "render": {
                "left":   { "layout": "vertical", "icon_pos": "left", "show_label": true },
                "bottom": { "layout": "icon-bar", "icon_pos": "top",  "show_label": true }
            },
            "items": [
                {
                    "id": "dash",
                    "name": "Dashboard",
                    "icon": "icon-dash",
                    "route": "/dash",
                    "submenu": {
                        "render": {
                            "top-sub": "tabs",
                            "right":   "submenu"
                        },
                        "items": [
                            {
                                "id": "ov",
                                "name": "Overview",
                                "icon": "icon-eye",
                                "route": "/dash/ov",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_TEST_VIEW",
                                    "kw": { "title": "Overview", "color": "#2A9D8F" },
                                    "lifecycle": "keep_alive"
                                }
                            },
                            {
                                "id": "devices",
                                "name": "Devices",
                                "icon": "icon-devices",
                                "route": "/dash/devices",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_TEST_VIEW",
                                    "kw": { "title": "Devices", "color": "#E76F51" },
                                    "lifecycle": "keep_alive"
                                }
                            },
                            {
                                "id": "alerts",
                                "name": "Alerts",
                                "icon": "icon-alerts",
                                "route": "/dash/alerts",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_TEST_VIEW",
                                    "kw": { "title": "Alerts", "color": "#E9C46A" },
                                    "lifecycle": "lazy_destroy"
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "reports",
                    "name": "Reports",
                    "icon": "icon-reports",
                    "route": "/reports",
                    "submenu": {
                        "render": {
                            "top-sub": "tabs",
                            "right":   "submenu"
                        },
                        "items": [
                            {
                                "id": "daily",
                                "name": "Daily",
                                "icon": "icon-day",
                                "route": "/reports/daily",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_TEST_VIEW",
                                    "kw": { "title": "Daily reports", "color": "#264653" }
                                }
                            },
                            {
                                "id": "monthly",
                                "name": "Monthly",
                                "icon": "icon-month",
                                "route": "/reports/monthly",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_TEST_VIEW",
                                    "kw": { "title": "Monthly reports", "color": "#F4A261" }
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "settings",
                    "name": "Settings",
                    "icon": "icon-gear",
                    "route": "/settings",
                    "target": {
                        "stage": "main",
                        "gclass": "C_TEST_VIEW",
                        "kw": { "title": "Settings", "color": "#6D597A" }
                    }
                },
                {
                    "id": "help",
                    "name": "Help",
                    "icon": "icon-help",
                    "route": "/help",
                    "target": {
                        "stage": "main",
                        "gclass": "C_TEST_VIEW",
                        "kw": { "title": "Help (eager)", "color": "#8338EC" },
                        "lifecycle": "eager"
                    }
                }
            ]
        },

        "quick": {
            "render": {
                "top-sub": "drawer"
            },
            "items": [
                { "id": "q-ov",       "name": "Quick: Overview", "icon": "icon-eye",    "route": "/dash/ov" },
                { "id": "q-alerts",   "name": "Quick: Alerts",   "icon": "icon-alerts", "route": "/dash/alerts" },
                { "id": "q-settings", "name": "Quick: Settings", "icon": "icon-gear",   "route": "/settings" }
            ]
        }
    }
}
