{
    "_comment": "Agent Console shell config — mobile-app style (wattyzer-like): an always-on top toolbar with a left brand + right-aligned status/actions (connection dot, language, settings dropdown), NO burger drawer. Primary nav (Console / TreeDB / Stats) is the left rail on desktop and the bottom icon-bar on mobile; submenus render as top tabs. Routes reached from the toolbar dropdown (settings/about) live in shell.routes. Every leaf currently targets C_GUI_AGENT_VIEW (placeholder) — real views replace them per phase.",

    "shell": {
        "breakpoints": "bulma",

        "zones": {
            "top":     { "host": "toolbar",        "show_on": "*" },
            "left":    { "host": "menu.primary",   "show_on": ">=desktop" },
            "bottom":  { "host": "menu.primary",   "show_on": "<desktop"  },
            "top-sub": { "host": "menu.secondary", "show_on": "*" },
            "center":  { "host": "stage.main" }
        },

        "stages": {
            "main": { "zone": "center", "default_route": "/console/agent" }
        },

        "_routes_comment": "Routes that are NOT a primary-menu item: reached from the toolbar settings dropdown. Kept here so each path is deep-linkable and survives reload.",
        "routes": {
            "/settings/agents": {
                "stage": "main",
                "gclass": "C_SETTINGS",
                "kw": { "title": "settings" },
                "lifecycle": "lazy_destroy"
            },
            "/settings/auth": {
                "stage": "main",
                "gclass": "C_AUTH_SETTINGS",
                "kw": { "title": "authentication" },
                "lifecycle": "lazy_destroy"
            },
            "/help/about": {
                "stage": "main",
                "gclass": "C_GUI_AGENT_VIEW",
                "kw": { "title": "About", "subtitle": "Yuneta Agent Console", "color": "#2E7CD6" },
                "lifecycle": "lazy_destroy"
            }
        }
    },

    "toolbar": {
        "zone": "top",
        "aria_label": "Agent Console toolbar",
        "items": [
            {
                "id": "brand",
                "type": "brand",
                "logo": "/agent-mark.svg",
                "wordmark": "Agent Console",
                "alt": "Agent Console",
                "aria_label": "Agent Console home",
                "action": { "type": "navigate", "route": "/console/agent" }
            },
            {
                "id": "conn",
                "type": "connection",
                "align": "end",
                "aria_label": "Agent connection status"
            },
            {
                "id": "lang",
                "icon": "yi-language",
                "name": "ES/EN",
                "align": "end",
                "aria_label": "Toggle language",
                "action": { "type": "event", "event": "EV_TOGGLE_LANGUAGE" }
            },
            {
                "id": "menu",
                "icon": "yi-gear",
                "align": "end",
                "aria_label": "Settings menu",
                "action": {
                    "type": "dropdown",
                    "items": [
                        {
                            "id": "set-agents",
                            "name": "Agents",
                            "icon": "yi-cloudversify",
                            "action": { "type": "navigate", "route": "/settings/agents" }
                        },
                        {
                            "id": "set-auth",
                            "name": "Authentication",
                            "icon": "yi-lock",
                            "action": { "type": "navigate", "route": "/settings/auth" }
                        },
                        { "type": "divider" },
                        {
                            "id": "about",
                            "name": "About",
                            "icon": "yi-question",
                            "action": { "type": "navigate", "route": "/help/about" }
                        }
                    ]
                }
            }
        ]
    },

    "menu": {
        "primary": {
            "render": {
                "left":   { "layout": "vertical", "icon_pos": "left", "show_label": true },
                "bottom": { "layout": "icon-bar", "icon_pos": "top",  "show_label": true }
            },
            "items": [
                {
                    "id": "console",
                    "name": "Console",
                    "icon": "yi-square-js",
                    "tooltip": "Control-plane CLI to a yuneta agent",
                    "route": "/console",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "agent",
                                "name": "Agent CLI",
                                "icon": "yi-square-js",
                                "route": "/console/agent",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_AGENT_CONSOLE",
                                    "kw": { "title": "console" },
                                    "lifecycle": "keep_alive"
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "treedb",
                    "name": "TreeDB",
                    "icon": "yi-hexagon-nodes",
                    "tooltip": "Browse treedb topics as tables and graphs",
                    "route": "/treedb",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "graph",
                                "name": "Graph",
                                "icon": "yi-hexagon-nodes",
                                "route": "/treedb/graph",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "TreeDB · Graph", "subtitle": "Nodes and links (Phase 3)", "color": "#1FAE6F" }
                                }
                            },
                            {
                                "id": "table",
                                "name": "Table",
                                "icon": "yi-table",
                                "route": "/treedb/table",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "TreeDB · Table", "subtitle": "Topic rows (Phase 3)", "color": "#1F8A5F" }
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "stats",
                    "name": "Stats",
                    "icon": "yi-eye",
                    "tooltip": "Live stats from a yuno",
                    "route": "/stats",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "live",
                                "name": "Live",
                                "icon": "yi-eye",
                                "route": "/stats/live",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "Stats · Live", "subtitle": "Time-series charts (Phase 3)", "color": "#F5A623" }
                                }
                            }
                        ]
                    }
                }
            ]
        }
    }
}
