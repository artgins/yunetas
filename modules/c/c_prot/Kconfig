config C_PROT_MODULE
    bool

config C_PROT
    bool "C_PROT support"
    default y
    help
      This option enables the C_PROT library.

if C_PROT

config C_PROT_MQTT
    bool "MQTT protocol support (c_prot_mqtt2)"
    default y
    help
      Enable the MQTT v3.1.1/v5.0 protocol implementation (c_prot_mqtt2,
      mqtt_util, tr2q_mqtt). Disable to exclude MQTT from the C_PROT build.

endif # C_PROT
