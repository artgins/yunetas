<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>{{Yunorole}} — Page Not Found</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <style>
        * { line-height: 1.2; margin: 0; box-sizing: border-box; }
        html {
            color: #5B6B7E;
            display: table;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            height: 100%;
            text-align: center;
            width: 100%;
            background: #F4F6F8;
        }
        body { display: table-cell; vertical-align: middle; padding: 2em; }
        h1 { color: #1F3A5F; font-size: 2.25em; font-weight: 600; margin-bottom: 0.5em; }
        p  { margin: 0 auto; max-width: 32em; }
        a  { color: #2E7CD6; text-decoration: none; }
        a:hover { text-decoration: underline; }
        @media (max-width: 320px) {
            h1 { font-size: 1.5em; }
        }
    </style>
</head>
<body>
    <h1>404 — Page Not Found</h1>
    <p>The page you were looking for doesn't exist.</p>
    <p style="margin-top: 1.5em;"><a href="/">Back to {{Yunorole}}</a></p>
</body>
</html>
<!-- IE needs 512+ bytes: https://learn.microsoft.com/en-us/archive/blogs/ieinternals/friendly-http-error-pages -->
