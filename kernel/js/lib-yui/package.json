{
    "name": "@yuneta/lib-yui",
    "version": "7.1.0",
    "type": "module",
    "main": "dist/lib-yui.cjs.js",
    "module": "dist/lib-yui.es.js",
    "browser": "dist/lib-yui.umd.js",
    "exports": {
        ".": {
            "import": "./dist/lib-yui.es.js",
            "require": "./dist/lib-yui.cjs.js"
        },
        "./src/*": "./src/*",
        "./vite-plugin-yuneta-html.js": "./vite-plugin-yuneta-html.js",
        "./skeleton/*": "./skeleton/*"
    },
    "files": [
        "dist/",
        "index.js",
        "src/",
        "skeleton/",
        "vite-plugin-yuneta-html.js"
    ],
    "description": "Yuneta UI Library - Reusable GUI components for Yuneta-based projects",
    "scripts": {
        "build": "vite build",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@rollup/plugin-terser": "^1.0.0",
        "vite": "^7.3.1"
    },
    "peerDependencies": {
        "@yuneta/gobj-js": "*",
        "@antv/g6": "^5.0.0",
        "bulma": "^1.0.0",
        "i18next": "^25.0.0",
        "maplibre-gl": "^5.0.0",
        "tabulator-tables": "^6.0.0",
        "tom-select": "^2.0.0",
        "uplot": "^1.6.0",
        "vanilla-jsoneditor": "^0.23.0"
    }
}
