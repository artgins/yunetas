{
    "_comment": "Agent Console shell config. Primary areas (Console / TreeDB / Stats) fit the mobile bottom-bar cleanly (<=5 icons). Settings and Help live in the burger drawer (menu.quick). Every leaf currently targets C_GUI_AGENT_VIEW (placeholder) — real views replace them per phase: Console -> C_AGENT_CONSOLE (Phase 1), Settings -> C_SETTINGS (Phase 1), TreeDB/Stats (Phase 3).",

    "shell": {
        "breakpoints": "bulma",

        "zones": {
            "top":     { "host": "toolbar",        "show_on": ">=tablet" },
            "left":    { "host": "menu.primary",   "show_on": ">=desktop" },
            "bottom":  { "host": "menu.primary",   "show_on": "<desktop"  },
            "top-sub": { "host": "menu.secondary", "show_on": "<desktop"  },
            "right":   { "host": "menu.secondary", "show_on": ">=desktop" },
            "center":  { "host": "stage.main" }
        },

        "stages": {
            "main": { "zone": "center", "default_route": "/console/agent" }
        }
    },

    "toolbar": {
        "zone": "top",
        "aria_label": "Agent Console toolbar",
        "items": [
            {
                "id": "burger",
                "icon": "yi-bars",
                "name": "",
                "aria_label": "Open quick menu",
                "action": { "type": "drawer", "op": "toggle", "menu_id": "quick" }
            },
            {
                "id": "lang",
                "icon": "yi-language",
                "name": "ES/EN",
                "align": "end",
                "aria_label": "Toggle language",
                "action": { "type": "event", "event": "EV_TOGGLE_LANGUAGE" }
            },
            {
                "id": "settings",
                "icon": "yi-gear",
                "name": "",
                "align": "end",
                "aria_label": "Settings",
                "action": { "type": "navigate", "route": "/settings/agents" }
            },
            {
                "id": "help",
                "icon": "yi-question",
                "name": "",
                "align": "end",
                "aria_label": "Help",
                "action": { "type": "navigate", "route": "/help/about" }
            }
        ]
    },

    "menu": {
        "primary": {
            "render": {
                "left":   { "layout": "vertical", "icon_pos": "left", "show_label": true },
                "bottom": { "layout": "icon-bar", "icon_pos": "top",  "show_label": true }
            },
            "items": [
                {
                    "id": "console",
                    "name": "Console",
                    "icon": "yi-square-js",
                    "tooltip": "Control-plane CLI to a yuneta agent",
                    "route": "/console",
                    "submenu": {
                        "render": { "top-sub": "tabs", "right": "submenu" },
                        "items": [
                            {
                                "id": "agent",
                                "name": "Agent CLI",
                                "icon": "yi-square-js",
                                "route": "/console/agent",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "Agent CLI", "subtitle": "Send control-plane commands to an agent (Phase 1)", "color": "#2E7CD6" },
                                    "lifecycle": "keep_alive"
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "treedb",
                    "name": "TreeDB",
                    "icon": "yi-hexagon-nodes",
                    "tooltip": "Browse treedb topics as tables and graphs",
                    "route": "/treedb",
                    "submenu": {
                        "render": { "top-sub": "tabs", "right": "submenu" },
                        "items": [
                            {
                                "id": "graph",
                                "name": "Graph",
                                "icon": "yi-hexagon-nodes",
                                "route": "/treedb/graph",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "TreeDB · Graph", "subtitle": "Nodes and links (Phase 3)", "color": "#1FAE6F" }
                                }
                            },
                            {
                                "id": "table",
                                "name": "Table",
                                "icon": "yi-table",
                                "route": "/treedb/table",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "TreeDB · Table", "subtitle": "Topic rows (Phase 3)", "color": "#1F8A5F" }
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "stats",
                    "name": "Stats",
                    "icon": "yi-eye",
                    "tooltip": "Live stats from a yuno",
                    "route": "/stats",
                    "submenu": {
                        "render": { "top-sub": "tabs", "right": "submenu" },
                        "items": [
                            {
                                "id": "live",
                                "name": "Live",
                                "icon": "yi-eye",
                                "route": "/stats/live",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "Stats · Live", "subtitle": "Time-series charts (Phase 3)", "color": "#F5A623" }
                                }
                            }
                        ]
                    }
                }
            ]
        },

        "quick": {
            "_comment": "Drawer opened from the burger toolbar item. Settings and Help live here so they don't take a primary-bar slot but still get a secondary nav when their routes are visited.",
            "render": { "top-sub": "drawer" },
            "items": [
                {
                    "id": "settings",
                    "name": "Settings",
                    "icon": "yi-gear",
                    "tooltip": "Agents and authentication (stored in this browser)",
                    "route": "/settings",
                    "submenu": {
                        "render": { "top-sub": "tabs", "right": "submenu" },
                        "items": [
                            {
                                "id": "agents",
                                "name": "Agents",
                                "icon": "yi-cloudversify",
                                "route": "/settings/agents",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "Settings · Agents", "subtitle": "Agent endpoints, stored locally (Phase 1)", "color": "#5B6B7E" }
                                }
                            },
                            {
                                "id": "auth",
                                "name": "Authentication",
                                "icon": "yi-lock",
                                "route": "/settings/auth",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "Settings · Authentication", "subtitle": "OIDC / auth URL, stored locally (Phase 2)", "color": "#4A5A6E" }
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "help",
                    "name": "Help",
                    "icon": "yi-question",
                    "tooltip": "About this console",
                    "route": "/help",
                    "submenu": {
                        "render": { "top-sub": "tabs", "right": "submenu" },
                        "items": [
                            {
                                "id": "about",
                                "name": "About",
                                "icon": "yi-question",
                                "route": "/help/about",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "About", "subtitle": "Yuneta Agent Console", "color": "#2E7CD6" }
                                }
                            }
                        ]
                    }
                }
            ]
        }
    }
}
