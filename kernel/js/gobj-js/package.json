{
    "name": "@yuneta/gobj-js",
    "version": "7.2.1",
    "description": "GObject + FSM runtime for JavaScript — event-driven components with typed attributes, pub/sub, and WebSocket inter-event client",
    "author": "ArtGins",
    "license": "MIT",
    "type": "module",
    "main": "dist/gobj-js.cjs.js",
    "module": "dist/gobj-js.es.js",
    "exports": {
        "import": "./dist/gobj-js.es.js",
        "require": "./dist/gobj-js.cjs.js"
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "vitest",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest --coverage",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@rollup/plugin-terser": "^1.0.0",
        "@vitest/coverage-v8": "^4.0.18",
        "vite": "^8.0.3",
        "vitest": "^4.0.18"
    },
    "dependencies": {
    }
}
