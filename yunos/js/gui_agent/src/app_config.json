{
    "_comment": "Agent Console shell config — mobile-app style: an always-on top toolbar with a left brand + right-aligned status/actions (connection dot, language, theme, user avatar). Primary nav (Console / TreeDB / Stats / Settings) is the left rail on desktop and the bottom icon-bar on mobile; submenus render as top tabs. The toolbar user avatar shows the logged-in user's initials and navigates to /settings/auth (login form when signed out).",

    "shell": {
        "breakpoints": "bulma",

        "zones": {
            "top":     { "host": "toolbar",        "show_on": "*" },
            "left":    { "host": "menu.primary",   "show_on": ">=desktop" },
            "bottom":  { "host": "menu.primary",   "show_on": "<desktop"  },
            "top-sub": { "host": "menu.secondary", "show_on": "*" },
            "center":  { "host": "stage.main" }
        },

        "stages": {
            "main": { "zone": "center", "default_route": "/console/agent" }
        }
    },

    "toolbar": {
        "zone": "top",
        "aria_label": "Agent Console toolbar",
        "items": [
            {
                "id": "brand",
                "type": "brand",
                "logo": "/agent-mark.svg",
                "wordmark": "Agent Console",
                "alt": "Agent Console",
                "aria_label": "Agent Console home",
                "action": { "type": "navigate", "route": "/console/agent" }
            },
            {
                "id": "conn",
                "type": "connection",
                "align": "end",
                "aria_label": "Agent connection status"
            },
            {
                "id": "lang",
                "icon": "yi-language",
                "name": "ES/EN",
                "align": "end",
                "aria_label": "Toggle language",
                "action": { "type": "event", "event": "EV_TOGGLE_LANGUAGE" }
            },
            {
                "id": "theme",
                "icon": "yi-moon",
                "name": "",
                "align": "end",
                "aria_label": "Toggle dark theme",
                "action": { "type": "event", "event": "EV_TOGGLE_THEME" }
            },
            {
                "id": "user",
                "type": "avatar",
                "align": "end",
                "aria_label": "Account / Sign in",
                "action": { "type": "navigate", "route": "/settings/auth" }
            }
        ]
    },

    "menu": {
        "primary": {
            "render": {
                "left":   { "layout": "vertical", "icon_pos": "left", "show_label": true },
                "bottom": { "layout": "icon-bar", "icon_pos": "top",  "show_label": true }
            },
            "items": [
                {
                    "id": "console",
                    "name": "Console",
                    "icon": "yi-square-js",
                    "tooltip": "Control-plane CLI to a yuneta agent",
                    "route": "/console",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "agent",
                                "name": "Agent CLI",
                                "icon": "yi-square-js",
                                "route": "/console/agent",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_AGENT_CONSOLE",
                                    "kw": { "title": "console" },
                                    "lifecycle": "keep_alive"
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "treedb",
                    "name": "TreeDB",
                    "icon": "yi-hexagon-nodes",
                    "tooltip": "Browse treedb topics as tables and graphs",
                    "route": "/treedb",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "graph",
                                "name": "Graph",
                                "icon": "yi-hexagon-nodes",
                                "route": "/treedb/graph",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "TreeDB · Graph", "subtitle": "Nodes and links (Phase 3)", "color": "#1FAE6F" }
                                }
                            },
                            {
                                "id": "table",
                                "name": "Table",
                                "icon": "yi-table",
                                "route": "/treedb/table",
                                "_target_comment": "WIP: C_TREEDB_PANEL + C_TREEDB_GATE are built but BLOCKED — JS C_IEVENT_CLI.mt_command routes the inter-event by kw.service, which collides with command-yuno's inner 'service' param (the agent then can't find the service). Needs a gobj-js fix to decouple routing-service from command params. Until then keep the placeholder.",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "TreeDB · Table", "subtitle": "Topic rows (Phase 3, WIP — blocked on a gobj-js routing fix)", "color": "#1F8A5F" }
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "stats",
                    "name": "Stats",
                    "icon": "yi-eye",
                    "tooltip": "Live stats from a yuno",
                    "route": "/stats",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "live",
                                "name": "Live",
                                "icon": "yi-eye",
                                "route": "/stats/live",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "Stats · Live", "subtitle": "Time-series charts (Phase 3)", "color": "#F5A623" }
                                }
                            }
                        ]
                    }
                },
                {
                    "id": "settings",
                    "name": "Settings",
                    "icon": "yi-gear",
                    "tooltip": "Agents, authentication, about",
                    "route": "/settings",
                    "submenu": {
                        "render": { "top-sub": "tabs" },
                        "items": [
                            {
                                "id": "agents",
                                "name": "Agents",
                                "icon": "yi-cloudversify",
                                "route": "/settings/agents",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_SETTINGS",
                                    "kw": { "title": "settings" },
                                    "lifecycle": "lazy_destroy"
                                }
                            },
                            {
                                "id": "auth",
                                "name": "Authentication",
                                "icon": "yi-lock",
                                "route": "/settings/auth",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_AUTH_SETTINGS",
                                    "kw": { "title": "authentication" },
                                    "lifecycle": "lazy_destroy"
                                }
                            },
                            {
                                "id": "about",
                                "name": "About",
                                "icon": "yi-question",
                                "route": "/settings/about",
                                "target": {
                                    "stage": "main",
                                    "gclass": "C_GUI_AGENT_VIEW",
                                    "kw": { "title": "About", "subtitle": "Yuneta Agent Console", "color": "#2E7CD6" }
                                }
                            }
                        ]
                    }
                }
            ]
        }
    }
}
